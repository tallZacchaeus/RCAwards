# Production environment for docker-compose.prod.yml.
# Copy to .env on the VPS and fill in real values. NEVER commit the real .env.

# The public domain (Caddy obtains the HTTPS certificate for this name).
SITE_DOMAIN=awards.thecitybreed.org

# Database — generate two strong passwords, e.g.:  openssl rand -base64 24
DB_ROOT_PASSWORD=CHANGE-ME-root-password
DB_PASSWORD=CHANGE-ME-app-password

# Auth — MUST be at least 32 bytes. Generate with:  openssl rand -hex 32
JWT_SECRET=CHANGE-ME-64-hex-chars

EDITION_YEAR=2026

# Outgoing email via Hostinger SMTP (optional — leave empty to disable).
# Create the mailbox in hPanel first (e.g. awards@thecitybreed.org).
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
