{
  "slug": "creche-of-the-year",
  "name": "Crèche of the Year",
  "group": "city",
  "edition_year": 2026,
  "sort_order": 1,
  "voting_enabled": true,
  "description": "This nomination is for a crèche within Redemption City that has demonstrated excellence in early childhood care, safety, innovation, and impact.",
  "sections": [
    {
      "title": "Your Details (the Nominator)",
      "fields": [
        {"key": "nominator_full_name", "label": "Your Full Name", "type": "short_text", "required": true},
        {"key": "nominator_contact", "label": "Your Phone Number / Email", "type": "short_text", "required": true},
        {"key": "relationship", "label": "Your Relationship to the Crèche", "type": "multiple_choice", "required": true, "allow_other": true,
          "options": ["Parent/Guardian", "Staff Member", "Neighbor", "Church Member", "Other (please specify)"]},
        {"key": "resides_in_city", "label": "Do you reside in Redemption City?", "type": "yes_no", "required": true}
      ]
    },
    {
      "title": "Nominee Details (the Crèche)",
      "fields": [
        {"key": "creche_name", "label": "Name of the Crèche Being Nominated", "type": "short_text", "required": true},
        {"key": "creche_location", "label": "Location of the Crèche", "type": "short_text", "required": true}
      ]
    },
    {
      "title": "Evaluation Criteria",
      "description": "Rate from 1 to 10 (1 = Poor, 10 = Excellent).",
      "fields": [
        {"key": "staff_child_ratio", "label": "Staff-to-child ratio and supervision quality", "type": "linear_scale_1_10", "required": true},
        {"key": "parental_satisfaction", "label": "Parental satisfaction and engagement", "type": "linear_scale_1_10", "required": true},
        {"key": "cleanliness_safety", "label": "Cleanliness, safety, and learning environment", "type": "linear_scale_1_10", "required": true},
        {"key": "community_involvement", "label": "Community involvement (e.g. events, parenting sessions)", "type": "linear_scale_1_10", "required": true}
      ]
    },
    {
      "title": "Optional Supporting Info",
      "fields": [
        {"key": "why_deserve", "label": "Why do you believe this Crèche deserves the award?", "type": "paragraph", "required": false},
        {"key": "supporting_file", "label": "Upload any supporting photo, flyer, or testimonial", "type": "file_upload", "required": false, "accept": ["image/*", "application/pdf"]}
      ]
    }
  ]
}
