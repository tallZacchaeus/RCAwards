# Copy to .env and adjust for your environment.

# "development" | "production". In production the app refuses to start with
# insecure defaults (weak JWT_SECRET or the default root DATABASE_URL).
ENVIRONMENT=development

# MySQL connection (SQLAlchemy URL). Uses PyMySQL driver.
DATABASE_URL=mysql+pymysql://root:root@localhost:3306/rcawards

EDITION_YEAR=2026

# Auth — MUST be a strong random value (>=32 bytes) in production.
JWT_SECRET=change-me-use-a-long-random-string-min-32-bytes
JWT_EXPIRE_MINUTES=720

# File uploads (local-disk storage in dev)
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=10

# CORS — the frontend origin(s), as a JSON array.
CORS_ORIGINS=["http://localhost:3000"]

# Per-IP rate limit for public write endpoints
RATE_LIMIT_REQUESTS=20
RATE_LIMIT_WINDOW_SECONDS=60
